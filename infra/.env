# Application
APP_ENV=development
SECRET_KEY=change-me
JWT_SECRET=change-me-in-production
JWT_SECRET_KEY=change-me-in-production

# CORS / frontend origins
CORS_ORIGINS='["http://localhost:3000"]'
ORIGENS_CORS='["http://localhost:3000"]'

# Frontend API base
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Postgres (adaptado para o serviço Docker Compose `db`)
POSTGRES_USER=checklist_admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=checklist_db
DATABASE_URL=postgresql+psycopg://checklist_admin:change-me@db:5432/checklist_db

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# S3 (optional)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# Other
MAX_UPLOAD_SIZE=10485760
